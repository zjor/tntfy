{
  "name": "tntfy",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,md}\"",
    "check-types": "turbo run check-types",
    "test": "turbo run test",
    "migrate": "turbo run migrate"
  },
  "devDependencies": {
    "prettier": "^3.7.4",
    "turbo": "^2.9.9",
    "typescript": "5.9.2"
  },
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["@nestjs/core", "esbuild"]
  }
}
